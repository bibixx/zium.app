{
  "name": "zium",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "yarn tsc && yarn lint && vite build",
    "preview": "vite preview",
    "lint:ts": "eslint src/**/*.{ts,tsx}",
    "lint:css:stylelint": "stylelint src/**/*.scss",
    "lint:css:prettier": "prettier -c src/**/*.scss",
    "lint:css": "yarn lint:css:stylelint && yarn lint:css:prettier",
    "lint": "yarn lint:ts && yarn lint:css",
    "type-check": "tsc --noEmit",
    "build-tokens:prepare:dark": "token-transformer --expandTypography --expandShadow --expandComposition --expandBorder src/tokens/dark.json src/tokens/dark.sd.json",
    "build-tokens:prepare:light": "token-transformer --expandTypography --expandShadow --expandComposition --expandBorder src/tokens/light.json src/tokens/light.sd.json",
    "build-tokens:prepare": "yarn build-tokens:prepare:dark && yarn build-tokens:prepare:light",
    "build-tokens:build:base": "style-dictionary build --config tokens.config.cjs",
    "build-tokens:build:light": "STYLE_DICTIONARY_MODE=light yarn run build-tokens:build:base",
    "build-tokens:build:dark": "STYLE_DICTIONARY_MODE=dark yarn run build-tokens:build:base",
    "build-tokens:build": "yarn run build-tokens:build:light && yarn run build-tokens:build:dark",
    "build-tokens:cleanup": "rm -f src/tokens/*.sd.json",
    "build-tokens": "yarn run build-tokens:prepare && yarn run build-tokens:build && yarn run build-tokens:cleanup && yarn run lint:css -w"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@popperjs/core": "^2.11.8",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/browser": "^10.5.0",
    "@sentry/react": "^10.5.0",
    "@sentry/vite-plugin": "^4.1.1",
    "@sindresorhus/transliterate": "^1.6.0",
    "bitmovin-player": "^8.223.0",
    "bitmovin-player-ui": "^3.102.0",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "eventemitter2": "^6.4.9",
    "fast-deep-equal": "^3.1.3",
    "focus-trap-react": "^11.0.4",
    "lottie-react": "^2.4.1",
    "lottie-web": "^5.13.0",
    "moize": "^6.1.6",
    "mpd-parser": "^1.3.1",
    "object-merge": "^2.5.1",
    "piwik-react-router": "^0.12.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intersection-observer": "^9.16.0",
    "react-popper": "^2.3.0",
    "react-router-dom": "^6.30.1",
    "react-transition-group": "^4.4.5",
    "ts-functional-pipe": "^3.1.2",
    "ts-key-enum": "^2.0.13",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@sentry/cli": "^2.52.0",
    "@types/object-merge": "^2.5.3",
    "@types/piwik-react-router": "^0.12.2",
    "@types/react": "18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/react-transition-group": "^4.4.12",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react-swc": "^4.0.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.6.2",
    "sass-embedded": "^1.90.0",
    "style-dictionary": "^3.9.2",
    "stylelint": "^16.23.1",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-value-no-unknown-custom-properties": "^6.0.1",
    "token-transformer": "^0.0.33",
    "typescript": "^5.9.2",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^7.1.3",
    "vite-plugin-svgr": "^4.3.0"
  },
  "packageManager": "yarn@3.5.0",
  "resolutions": {
    "lottie-react@^2.4.0": "patch:lottie-react@npm%3A2.4.0#./.yarn/patches/lottie-react-npm-2.4.0-d4d95c55aa.patch",
    "bitmovin-player-ui@^3.50.0": "patch:bitmovin-player-ui@npm%3A3.51.0#./.yarn/patches/bitmovin-player-ui-npm-3.51.0-bff36d4016.patch"
  }
}
